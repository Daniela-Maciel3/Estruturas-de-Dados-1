//Exemplo de Cadastro usando struct
  #include <stdio.h>
  #include <string.h>
      struct Aluno {
          char nome[50];
          int idade;
          float nota;
      };
      int main() {
      struct Aluno a1;
      strcpy(a1.nome, "Maria");
      a1.idade = 19;
      a1.nota = 9.2;
      printf("Nome: %s\n", a1.nome);
      printf("Idade: %d\n", a1.idade);
      printf("Nota: %.2f\n", a1.nota);
      return 0;
      }
//Exemplo com leitura de dados
  #include <stdio.h>
      struct Pessoa {
          char nome[50];
          int idade;
      };
      int main() {
      struct Pessoa p;
      printf("Digite o nome: ");
      scanf(" %[^\n]", p.nome);
      printf("Digite a idade: ");
      scanf("%d", &p.idade);
      printf("\n--- DADOS INFORMADOS ---\n");
      printf("Nome: %s\n", p.nome);
      printf("Idade: %d\n", p.idade);
      return 0;
      }
